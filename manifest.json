{
  "manifest_version": 3,
  "name": "Lionizon",
  "version": "1.0",
  "permissions": ["webRequest", "storage", "alarms", "cookies", "declarativeNetRequest", "declarativeNetRequestWithHostAccess"],
  "host_permissions": [
    "https://friends.roblox.com/*",
    "https://presence.roblox.com/*",
    "*://*.roblox.com/*"
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.roblox.com/*"],
      "run_at": "document_start",
      "css": [
        "css/cal-heatmap.css",
        "css/general.css",
        "css/pages/games.css",
        "css/pages/settings.css"
      ],
      "js": [
        "lib/d3.v7.min.js",
        "lib/cal-heatmap.min.js",
        "lib/popper.min.js",
        "lib/tooltip.min.js",
        "lib/chart.umd.js",
        "utils/misc.js",
        "utils/roblox_api.js",
        "scripts/pages/games/games.js",
        "scripts/pages/home/home.js",
        "scripts/pages/home/fast_buttons.js",
        "scripts/pages/general/settings.js",
        "scripts/pages/general/robux_to_currency.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["scripts/pages/games/inject.js", "assets/*"],
      "matches": ["*://*.roblox.com/*"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  }
}